# VoxHF Relay development settings.
#
# Copy this file to apps/relay/.env, change VOXHF_RELAY_TOKEN, then run:
# npm run relay:env

# Keep 127.0.0.1 for local development. Use 0.0.0.0 only behind a trusted
# firewall or reverse proxy.
VOXHF_RELAY_HOST=127.0.0.1
VOXHF_RELAY_PORT=8787

# Replace this before exposing the relay outside your machine.
# Recommended: openssl rand -hex 32
VOXHF_RELAY_TOKEN=hex-token-from-openssl-rand-hex-32

# Optional multi-user preview. Use this instead of, or in addition to, the
# single token above when one relay must host independent users. Each token is
# scoped to one user id; users cannot see each other's agents or pairings.
# Format: user_id=token,user_id_2=token_2
# Helper: npm run relay:user -- add daniele --env apps/relay/.env
# VOXHF_RELAY_USERS=daniele=hex-token-1,second_user=hex-token-2

# Comma-separated web origins that may open browser WebSockets to the relay.
# Add your hosted webapp origin here when testing a static/hosted webapp.
VOXHF_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8787,http://127.0.0.1:8787

# Pairing is required by default. Codes are short-lived and always in memory.
# Browser authorizations persist in pairings.json for env mode, or in SQLite
# when VOXHF_RELAY_AUTH_MODE is sqlite-fallback/sqlite.
VOXHF_RELAY_REQUIRE_PAIRING=true
VOXHF_PAIRING_TTL_MS=600000
VOXHF_RELAY_PERSIST_PAIRINGS=true

# Runtime state. This folder is ignored by git.
VOXHF_RELAY_DATA_DIR=.voxhf-relay
# Backups and pre-restore database copies older than this are removed daily.
VOXHF_BACKUP_DIR=.voxhf-relay/backups
VOXHF_BACKUP_RETENTION_DAYS=30
# Used only by env mode pairing persistence. SQLite modes use the database.
VOXHF_RELAY_PAIRINGS_FILE=.voxhf-relay/pairings.json

# Relay authentication mode.
# env             = use only VOXHF_RELAY_TOKEN / VOXHF_RELAY_USERS.
# sqlite-fallback = use SQLite tokens plus the .env fallback.
# sqlite          = use only SQLite tokens.
VOXHF_RELAY_AUTH_MODE=env
VOXHF_RELAY_DATABASE=.voxhf-relay/voxhf.db

# Temporary compatibility for older local agents that put their credential in
# the WebSocket URL. Set false after every agent using this relay is updated.
VOXHF_RELAY_ALLOW_AGENT_QUERY_TOKEN=true

# Bootstrap/break-glass token for /admin. The browser uses it only to create or
# recover the owner; normal administration uses a password and HttpOnly cookie.
# Keep it different from every relay user token. Recommended: openssl rand -hex 32
# VOXHF_RELAY_ADMIN_TOKEN=hex-token-from-openssl-rand-hex-32
VOXHF_RELAY_ADMIN_SESSION_TTL_MS=43200000
VOXHF_RELAY_ADMIN_SESSION_IDLE_TTL_MS=1800000

# Optional account login/registration for hosted browser sessions. Requires
# sqlite-fallback or sqlite auth mode. Registration is invite-only by default;
# create one-time codes from /admin after the relay starts.
VOXHF_RELAY_ENABLE_REGISTRATION=false
VOXHF_RELAY_REQUIRE_REGISTRATION_INVITE=true
VOXHF_RELAY_REGISTRATION_INVITE_TTL_MS=86400000
VOXHF_RELAY_SESSION_TTL_MS=2592000000
VOXHF_RELAY_ACCOUNT_RECOVERY_TTL_MS=1800000

# Deployment-specific legal document identifiers. Change a version whenever
# users must accept a materially updated document.
VOXHF_LEGAL_TERMS_VERSION=1.0
VOXHF_LEGAL_PRIVACY_VERSION=1.0
VOXHF_LEGAL_EFFECTIVE_DATE=

# Privacy defaults. Account/session/token rows remain necessary for login, but
# IP/user-agent metadata and audit history are optional. When audit persistence
# is disabled, startup maintenance also removes existing audit rows.
VOXHF_RELAY_STORE_SESSION_METADATA=false
VOXHF_RELAY_PERSIST_AUDIT=false
VOXHF_RELAY_AUDIT_RETENTION_DAYS=7

# Simple per-connection pressure limits for the preview relay.
VOXHF_RELAY_MAX_CLIENTS=100
VOXHF_RELAY_RATE_WINDOW_MS=10000
VOXHF_RELAY_MAX_MESSAGES_PER_WINDOW=240
VOXHF_RELAY_MAX_COMMANDS_PER_WINDOW=80
VOXHF_RELAY_MAX_PAIRING_ATTEMPTS_PER_WINDOW=10
VOXHF_RELAY_MAX_AUTH_ATTEMPTS_PER_WINDOW=10
VOXHF_RELAY_MAX_ADMIN_ATTEMPTS_PER_WINDOW=20
VOXHF_RELAY_MAX_AUDIO_FRAME_BYTES=32768
VOXHF_RELAY_MAX_REMOTE_TX_DURATION_MS=120000

# Update notice shown to hosted browsers when their local VoxHF agent is old.
# Leave the version values empty to use the relay package version as the
# recommended agent version. Set MINIMUM only for incompatible old agents.
VOXHF_UPDATE_DOWNLOAD_URL=https://github.com/leledeste/voxhf/releases/latest
VOXHF_RELAY_RECOMMENDED_AGENT_VERSION=
VOXHF_RELAY_MINIMUM_AGENT_VERSION=
