# VoxHF private deployment values.
#
# Recommended: run npm run setup -- server to generate infra/docker/.env.
# For manual setup, copy this file and change every placeholder before starting:
# docker compose -f infra/docker/docker-compose.yml --env-file infra/docker/.env up -d --build
#
# Safe operational defaults live in the Git-tracked defaults.env file and are
# updated automatically by git pull. Add a key to this private .env only when
# you intentionally want to override its standard value.

# DNS for all hosts must point to the VPS running Caddy.
LANDING_DOMAIN=voxhf.com
WEBAPP_DOMAIN=app.voxhf.com
RELAY_DOMAIN=relay.voxhf.com
CADDY_ACME_EMAIL=you@example.com

# Optional deployment-specific legal pages. Without these overrides Caddy
# serves the neutral templates included in webapp/. Keep custom files in the
# ignored private folder so Git and release packages cannot publish them.
# VOXHF_LEGAL_PRIVACY_FILE=./private/legal/privacy.html
# VOXHF_LEGAL_TERMS_FILE=./private/legal/terms.html
# Increment these identifiers whenever the corresponding document changes.
# VOXHF_LEGAL_TERMS_VERSION=1.0
# VOXHF_LEGAL_PRIVACY_VERSION=1.0
# VOXHF_LEGAL_EFFECTIVE_DATE=2026-07-15

# Host folder mounted into the relay container for SQLite backups. Relative
# paths are resolved from infra/docker.
# VOXHF_BACKUP_HOST_DIR=./backups
# Automatic cleanup defaults to 30 days in defaults.env. Override only when
# your retention policy requires a different period.
# VOXHF_BACKUP_RETENTION_DAYS=30

# Private-token mode only: replace this with a long random hex token. The local
# agent and browser Remote settings use the same value. Account mode leaves it
# empty and issues one personal agent token per registered user.
# Recommended: openssl rand -hex 32
VOXHF_RELAY_TOKEN=hex-token-from-openssl-rand-hex-32

# Optional multi-user preview. Use this when one self-hosted relay should serve
# multiple independent users. Each user gets a different token and can see only
# their own agents/pairings.
# Format: user_id=token,user_id_2=token_2
# Helper: npm run relay:user -- add daniele --env infra/docker/.env
# VOXHF_RELAY_USERS=daniele=hex-token-1,second_user=hex-token-2

# Exact browser origins allowed to connect to the relay.
# Include the hosted webapp origin. Include the relay origin only if you also
# test browser pages from the relay domain.
VOXHF_ALLOWED_ORIGINS=https://app.voxhf.com,https://relay.voxhf.com

# Relay authentication mode.
# env             = use only VOXHF_RELAY_TOKEN / VOXHF_RELAY_USERS.
# sqlite-fallback = use SQLite tokens plus the .env fallback.
# sqlite          = use only SQLite tokens.
VOXHF_RELAY_AUTH_MODE=env

# Temporary compatibility for older local agents that put their credential in
# the WebSocket URL. Set false after every agent using this relay is updated.
# VOXHF_RELAY_ALLOW_AGENT_QUERY_TOKEN=false

# Bootstrap and break-glass token for https://relay.voxhf.com/admin. Daily
# access uses the owner password and an HttpOnly session. Keep this different
# from relay user tokens.
# Recommended: openssl rand -hex 32
# VOXHF_RELAY_ADMIN_TOKEN=hex-token-from-openssl-rand-hex-32

# Optional passkey configuration for the admin panel. MFA is always opt-in.
# The relay derives the RP ID from the admin page origin by default. Set this
# only when you deliberately want a stable parent/specific domain binding.
# VOXHF_RELAY_WEBAUTHN_RP_ID=relay.voxhf.com

# Optional account login/registration for the hosted webapp. Requires
# sqlite-fallback or sqlite auth mode. Registration is invite-only by default;
# create one-time codes from the relay admin panel.
VOXHF_RELAY_ENABLE_REGISTRATION=false

# Enable this only on the central directory host serving voxhf.com.
# VOXHF_DIRECTORY_REGISTRY_ENABLED=true

# Optional public directory listing for this server. Registration in the
# directory is manual; its operator receives the heartbeat token once.
# VOXHF_DIRECTORY_PUBLISH=true
# VOXHF_DIRECTORY_HEARTBEAT_URL=https://voxhf.com/directory/api/heartbeat
# VOXHF_DIRECTORY_HEARTBEAT_TOKEN=hex-token-issued-by-directory-admin
