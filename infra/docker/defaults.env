# VoxHF Docker defaults tracked by Git.
#
# Do not place domains, email addresses, tokens, or other private deployment
# values in this file. Put those values in infra/docker/.env instead. Compose
# loads .env after this file, so explicit private overrides always win.

# Browser pairing.
VOXHF_RELAY_REQUIRE_PAIRING=true
VOXHF_PAIRING_TTL_MS=600000
VOXHF_RELAY_PERSIST_PAIRINGS=true

# Persistent paths inside the relay-data Docker volume.
VOXHF_RELAY_DATA_DIR=/var/lib/voxhf-relay
VOXHF_BACKUP_DIR=/var/backups/voxhf
VOXHF_BACKUP_RETENTION_DAYS=30
VOXHF_RELAY_PAIRINGS_FILE=/var/lib/voxhf-relay/pairings.json
VOXHF_RELAY_DATABASE=/var/lib/voxhf-relay/voxhf.db

# Invite-only account and session defaults.
VOXHF_RELAY_REQUIRE_REGISTRATION_INVITE=true
VOXHF_RELAY_REGISTRATION_INVITE_TTL_MS=86400000
VOXHF_RELAY_SESSION_TTL_MS=2592000000
VOXHF_RELAY_ACCOUNT_RECOVERY_TTL_MS=1800000

# Version identifiers recorded when a user accepts deployment-specific legal
# documents. Override them whenever the corresponding text materially changes.
VOXHF_LEGAL_TERMS_VERSION=1.0
VOXHF_LEGAL_PRIVACY_VERSION=1.0
VOXHF_LEGAL_EFFECTIVE_DATE=
# Remove this compatibility path after all local agents use header auth.
VOXHF_RELAY_ALLOW_AGENT_QUERY_TOKEN=true

# Admin sessions use a shorter absolute and idle lifetime than pilot sessions.
VOXHF_RELAY_ADMIN_SESSION_TTL_MS=43200000
VOXHF_RELAY_ADMIN_SESSION_IDLE_TTL_MS=1800000
VOXHF_RELAY_ADMIN_MFA_CHALLENGE_TTL_MS=300000
VOXHF_RELAY_WEBAUTHN_RP_NAME=VoxHF Relay

# Privacy-first storage defaults.
VOXHF_RELAY_STORE_SESSION_METADATA=false
VOXHF_RELAY_PERSIST_AUDIT=false
VOXHF_RELAY_AUDIT_RETENTION_DAYS=7

# Per-connection pressure and safety limits.
VOXHF_RELAY_MAX_CLIENTS=100
VOXHF_RELAY_RATE_WINDOW_MS=10000
VOXHF_RELAY_MAX_MESSAGES_PER_WINDOW=240
VOXHF_RELAY_MAX_COMMANDS_PER_WINDOW=80
VOXHF_RELAY_MAX_PAIRING_ATTEMPTS_PER_WINDOW=10
VOXHF_RELAY_MAX_AUTH_ATTEMPTS_PER_WINDOW=10
VOXHF_RELAY_MAX_ADMIN_ATTEMPTS_PER_WINDOW=20
VOXHF_RELAY_MAX_AUDIO_FRAME_BYTES=32768
VOXHF_RELAY_MAX_REMOTE_TX_DURATION_MS=120000

# Hosted-browser update notices.
VOXHF_UPDATE_DOWNLOAD_URL=https://github.com/leledeste/voxhf/releases/latest
VOXHF_RELAY_RECOMMENDED_AGENT_VERSION=
VOXHF_RELAY_MINIMUM_AGENT_VERSION=

# Public server directory. A private/self-hosted relay is not listed unless its
# operator explicitly enables publishing and receives a registry token.
VOXHF_DIRECTORY_REGISTRY_ENABLED=false
VOXHF_DIRECTORY_ONLINE_TTL_MS=300000
VOXHF_DIRECTORY_PUBLISH=false
VOXHF_DIRECTORY_HEARTBEAT_MS=60000
