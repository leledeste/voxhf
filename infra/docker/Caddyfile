{
  email {$CADDY_ACME_EMAIL}
}

{$RELAY_DOMAIN} {
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy no-referrer
    X-Frame-Options DENY
    Strict-Transport-Security "max-age=31536000"
    Permissions-Policy "camera=(), geolocation=(), microphone=(), payment=(), usb=()"
  }

  reverse_proxy voxhf-relay:8787
}

{$LANDING_DOMAIN} {
  encode zstd gzip

  root * /srv/voxhf-webapp
  route {
    @directory path /directory/api/*
    reverse_proxy @directory voxhf-relay:8787

    @setup path /setup /setup/
    rewrite @setup /setup.html
    @servers path /servers /servers/
    rewrite @servers /servers.html
    @privacy path /privacy /privacy/
    rewrite @privacy /privacy.html
    @terms path /terms /terms/
    rewrite @terms /terms.html

    @workspaceFiles path /app.html /app.js /styles.css /weather.js /login.html /auth.js /login /register
    respond @workspaceFiles 404

    try_files {path} /index.html
    file_server
  }

  @html path / /index.html /privacy /privacy/ /privacy.html /terms /terms/ /terms.html /setup /setup/ /setup.html /servers /servers/ /servers.html
  header @html Cache-Control "no-store"

  @release path /release.json
  header @release Cache-Control "no-store"

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy no-referrer
    X-Frame-Options DENY
    Strict-Transport-Security "max-age=31536000"
    Permissions-Policy "camera=(), geolocation=(), microphone=(), payment=(), usb=()"
    Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'"
  }
}

{$WEBAPP_DOMAIN} {
  encode zstd gzip

  root * /srv/voxhf-webapp
  route {
    @login path /login
    rewrite @login /login.html
    @register path /register
    rewrite @register /login.html
    @privacy path /privacy /privacy/
    rewrite @privacy /privacy.html
    @terms path /terms /terms/
    rewrite @terms /terms.html
    @root path /
    rewrite @root /app.html

    try_files {path} /app.html
    file_server
  }

  @html path / /app.html /login /register /login.html /privacy /privacy/ /privacy.html /terms /terms/ /terms.html
  header @html Cache-Control "no-store"

  @release path /release.json
  header @release Cache-Control "no-store"

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy no-referrer
    X-Frame-Options DENY
    Strict-Transport-Security "max-age=31536000"
    Permissions-Policy "camera=(), geolocation=(), microphone=(self), payment=(), usb=()"
    Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https: wss:; media-src 'self' blob:; base-uri 'none'; frame-ancestors 'none'; form-action 'self'"
  }
}
